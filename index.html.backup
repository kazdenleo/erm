        bindForm('ozonForm', storageKeys.ozon, ['client_id', 'api_key'], 'ozonTestBtn', testOzon);
        bindForm('wbForm', storageKeys.wb, ['api_key'], 'wbTestBtn', testWB);
        bindForm('ymForm', storageKeys.ym, ['api_key', 'campaign_id', 'business_id'], 'ymTestBtn', testYM);

        // Marketplace categories API
        async function fetchOzonCategories() {
          // Get stored Ozon credentials
          const ozonConfig = loadConfig(storageKeys.ozon);
          const params = new URLSearchParams();
          if (ozonConfig.client_id) params.append('client_id', ozonConfig.client_id);
          if (ozonConfig.api_key) params.append('api_key', ozonConfig.api_key);
          
          const url = `http://localhost:3001/categories/ozon?${params.toString()}`;
          try {
            const r = await fetch(url, { 
              method: 'GET',
              signal: AbortSignal.timeout(10000) // 10 second timeout
            });
            
            if (!r.ok) {
              const errorText = await r.text().catch(() => 'Неизвестная ошибка');
              return { ok: false, data: [], message: `HTTP ${r.status}: ${errorText.slice(0, 200)}` };
            }
            
            const json = await r.json().catch(() => ({}));
            return { ok: json.ok === true, data: json.data || [], message: json.message };
          } catch (e) {
            if (e.name === 'AbortError') {
              return { ok: false, data: [], message: 'Таймаут подключения (10 сек)' };
            }
            return { ok: false, data: [], message: `Ошибка подключения: ${e.message}` };
          }
        }

