            }
            
            const json = await r.json().catch(() => ({}));
            return { ok: json.ok === true, message: json.message || 'Подключение к Wildberries успешно' };
          } catch (e) {
            if (e.name === 'AbortError') {
              return { ok: false, message: 'Таймаут подключения (15 сек)' };
            }
            if (e.name === 'TypeError' && e.message.includes('fetch')) {
              return { ok: false, message: 'Сервер недоступен. Убедитесь, что сервер запущен на порту 3001.' };
            }
            return { ok: false, message: `Ошибка подключения: ${e.message}` };
