<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Купить</title>
    <style>
      :root {
        --bg: #0b0f14;
        --card: #111827;
        --text: #e5e7eb;
        --muted: #9ca3af;
        --primary: #2563eb;
        --primary-600: #1d4ed8;
        --ring: rgba(37, 99, 235, 0.5);
      }

      * { box-sizing: border-box; }

      html, body {
        height: 100%;
        margin: 0;
        background: radial-gradient(1200px 600px at 10% 10%, #111827 0%, #0b0f14 40%, #05070a 100%);
        color: var(--text);
        font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      }

      .container {
        min-height: 100%;
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 0;
      }

      aside.sidebar {
        border-right: 1px solid rgba(255,255,255,0.08);
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));
        padding: 16px;
      }
      .brand { font-size: 16px; margin: 0 0 12px; color: var(--muted); }
      .nav {
        display: flex; flex-direction: column; gap: 8px;
      }
      .nav .nav-btn {
        width: 100%; text-align: left; padding: 10px 12px; border-radius: 10px;
        background: transparent; color: var(--text); border: 1px solid rgba(255,255,255,0.08); cursor: pointer;
      }
      .nav .nav-btn.active {
        background: rgba(255,255,255,0.06);
        border-color: rgba(255,255,255,0.12);
      }

      main.content { padding: 24px; display: grid; align-items: start; justify-content: center; }
      .page { display: none; }
      .page.active { display: block; }

      .card {
        width: 100%;
        max-width: 460px;
        background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.04);
        backdrop-filter: blur(6px);
      }

      .title {
        margin: 0 0 8px;
        font-size: 22px;
        letter-spacing: 0.2px;
      }

      .subtitle {
        margin: 0 0 20px;
        color: var(--muted);
        font-size: 14px;
      }

      .actions {
        display: flex;
        gap: 12px;
      }

      .btn {
        appearance: none;
        cursor: pointer;
        border: 0;
        outline: none;
        padding: 12px 18px;
        font-size: 15px;
        border-radius: 12px;
        transition: transform 120ms ease, box-shadow 120ms ease, background-color 120ms ease, color 120ms ease;
        will-change: transform;
      }

      .btn-primary {
        background: linear-gradient(180deg, var(--primary), var(--primary-600));
        color: white;
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.35), 0 0 0 0 var(--ring);
      }
      .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(37, 99, 235, 0.45), 0 0 0 6px var(--ring);
      }
      .btn-primary:active {
        transform: translateY(0);
        box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35), 0 0 0 4px var(--ring);
      }

      .btn-secondary {
        background: transparent;
        color: var(--text);
        border: 1px solid rgba(255,255,255,0.12);
      }
      .btn-secondary:hover {
        background: rgba(255,255,255,0.04);
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* Modal */
      .hidden { display: none; }
      .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        z-index: 50;
      }
      .modal-backdrop.hidden { pointer-events: none; }
      .modal {
        width: 100%;
        max-width: 520px;
        background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.06);
        backdrop-filter: blur(8px);
        color: var(--text);
        position: relative;
        z-index: 100;
        pointer-events: auto;
      }
      .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 24px 12px;
      }
      .modal-title {
        margin: 0;
        font-size: 18px;
      }
      .modal-close {
        background: transparent;
        border: 0;
        color: var(--muted);
        font-size: 18px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        min-height: 36px;
        border-radius: 10px;
        padding: 6px;
        margin: -6px;
      }
      .modal-body { padding: 0 24px 20px; }
      .modal-footer { padding: 12px 24px 20px; display: flex; gap: 12px; justify-content: flex-end; }

      .field { margin: 12px 0; }
      .label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 6px; }
      .input, .textarea {
        width: 100%;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(0,0,0,0.25);
        color: var(--text);
        outline: none;
        transition: box-shadow 120ms ease, border-color 120ms ease;
      }
      .input:focus, .textarea:focus { box-shadow: 0 0 0 4px var(--ring); border-color: var(--primary); }
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      .error { color: #fca5a5; font-size: 12px; margin-top: 6px; min-height: 14px; }

      /* Tabs */
      .tabs { display: flex; gap: 8px; padding: 0 24px; margin-top: 4px; }
      .tab-btn {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        color: var(--text);
        padding: 8px 12px;
        border-radius: 10px;
        cursor: pointer;
      }
      .tab-btn[aria-selected="true"] {
        background: linear-gradient(180deg, var(--primary), var(--primary-600));
        border-color: transparent;
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.35);
      }
      .tab-btn:focus-visible {
        outline: none;
        box-shadow: 0 0 0 4px var(--ring);
      }
      .tab-panel { display: none; padding: 12px 24px 8px; }
      .tab-panel.active { display: block; }
    </style>
  </head>
  <body>
    <div class="container">
      <aside class="sidebar" role="navigation" aria-label="Основное меню">
        <h2 class="brand">ERP Demo</h2>
        <div class="nav">
          <button id="navHome" class="nav-btn active" type="button">Главная</button>
          <button id="navProducts" class="nav-btn" type="button">Товары</button>
          <button id="navCategories" class="nav-btn" type="button">Категории</button>
          <button id="navConnections" class="nav-btn" type="button">Подключения по API</button>
        </div>
      </aside>
      <main class="content">
        <section id="page-home" class="page active">
          <div class="card" role="region" aria-labelledby="card-title">
            <h1 id="card-title" class="title">Оформление заказа</h1>
            <p class="subtitle">Нажмите, чтобы добавить товар в корзину и перейти к оплате.</p>
            <div class="actions">
              <button id="buyButton" class="btn btn-primary" type="button" aria-label="Купить сейчас">Купить</button>
              <button id="detailsButton" class="btn btn-secondary" type="button">Подробнее</button>
              <button id="mpSettingsButton" class="btn btn-secondary" type="button">Настроить маркетплейсы</button>
            </div>
          </div>
        </section>
        <section id="page-products" class="page">
          <div class="card" role="region" aria-labelledby="products-title">
            <h1 id="products-title" class="title">Управление товарами</h1>
            <p class="subtitle">Просмотр, добавление и редактирование товаров в системе.</p>
            <div id="productsList" style="margin: 16px 0;"></div>
            <div class="actions">
              <button id="addProductBtn" class="btn btn-primary" type="button">Добавить товар</button>
              <button id="importProductsBtn" class="btn btn-secondary" type="button">Импорт товаров</button>
            </div>
          </div>
        </section>

        <section id="page-categories" class="page">
          <div class="card" role="region" aria-labelledby="categories-title">
            <h1 id="categories-title" class="title">Управление категориями</h1>
            <p class="subtitle">Создание и сопоставление категорий товаров с маркетплейсами.</p>
            <div id="categoriesList" style="margin: 16px 0;"></div>
            <div class="actions">
              <button id="addCategoryBtn" class="btn btn-primary" type="button">Добавить категорию</button>
              <button id="importCategoriesBtn" class="btn btn-secondary" type="button">Импорт категорий</button>
            </div>
          </div>
        </section>

        <section id="page-connections" class="page" aria-labelledby="connections-title">
          <div class="card" role="region">
            <h1 id="connections-title" class="title">Подключения по API</h1>
            <p class="subtitle">Здесь отображаются сохранённые настройки подключений к маркетплейсам.</p>
            <div id="connectionsList" style="margin: 16px 0;"></div>
            <div class="actions">
              <button id="connectApiBtn" class="btn btn-primary" type="button">Подключить по API</button>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script>
      (function () {
        function init() {
        const buyButton = document.getElementById('buyButton');
        const detailsButton = document.getElementById('detailsButton');
        const mpSettingsButton = document.getElementById('mpSettingsButton');
        const navHome = document.getElementById('navHome');
        const navProducts = document.getElementById('navProducts');
        const navCategories = document.getElementById('navCategories');
        const navConnections = document.getElementById('navConnections');
        const pageHome = document.getElementById('page-home');
        const pageProducts = document.getElementById('page-products');
        const pageCategories = document.getElementById('page-categories');
        const pageConnections = document.getElementById('page-connections');
        const connectionsList = document.getElementById('connectionsList');
        const connectApiBtn = document.getElementById('connectApiBtn');

        // Modal elements
        const modalBackdrop = document.getElementById('productModalBackdrop');
        const modalDialog = document.getElementById('productModal');
        const modalForm = document.getElementById('productForm');
        const closeBtn = document.getElementById('modalCloseBtn');
        const cancelBtn = document.getElementById('modalCancelBtn');

        function openModal() {
          if (!modalBackdrop || !modalDialog) return;
          modalBackdrop.classList.remove('hidden');
          modalDialog.classList.remove('hidden');
          modalBackdrop.style.display = 'flex';
          modalDialog.style.display = '';
          modalBackdrop.style.pointerEvents = 'auto';
          modalDialog.style.pointerEvents = 'auto';
          document.body.style.overflow = 'hidden';
          const firstInput = modalForm && modalForm.querySelector('input, textarea');
          if (firstInput) { firstInput.focus(); }
        }

        function closeModal() {
          if (!modalBackdrop || !modalDialog) return;
          const active = document.activeElement;
          if (active && modalDialog.contains(active) && active instanceof HTMLElement) { active.blur(); }
          modalDialog.classList.add('hidden');
          modalBackdrop.classList.add('hidden');
          modalBackdrop.style.pointerEvents = 'none';
          modalDialog.style.pointerEvents = 'none';
          modalBackdrop.style.display = 'none';
          modalDialog.style.display = 'none';
          document.body.style.overflow = '';
          if (buyButton) buyButton.focus();
        }

        if (buyButton) {
          buyButton.addEventListener('click', function () {
            openModal();
          });
        }

        if (detailsButton) {
          detailsButton.addEventListener('click', function () {
            alert('Здесь могли бы быть подробности о товаре.');
          });
        }

        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        if (cancelBtn) cancelBtn.addEventListener('click', function (e) { e.preventDefault(); closeModal(); });
        if (modalBackdrop) {
          modalBackdrop.addEventListener('click', function (e) {
            if (e.target === modalBackdrop) closeModal();
          });
        }

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modalBackdrop && !modalBackdrop.classList.contains('hidden')) {
            closeModal();
          }
        });

        if (modalForm) {
          modalForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(modalForm);
            const payload = {
              name: String(formData.get('name') || '').trim(),
              sku: String(formData.get('sku') || '').trim(),
              price: Number(formData.get('price') || 0),
              quantity: Number(formData.get('quantity') || 1),
              description: String(formData.get('description') || '').trim()
            };

            // Basic validation
            const errors = [];
            if (!payload.name) errors.push('Введите название товара');
            if (!payload.sku) errors.push('Введите артикул');
            if (!Number.isFinite(payload.price) || payload.price <= 0) errors.push('Цена должна быть больше 0');
            if (!Number.isInteger(payload.quantity) || payload.quantity <= 0) errors.push('Количество должно быть целым > 0');

            const errorBox = document.getElementById('formErrors');
            if (errorBox) errorBox.textContent = errors[0] || '';
            if (errors.length) return;

            // Imitate sending to ERP API — replace with real fetch later
            console.log('[ERP] Creating product:', payload);
            alert('Товар сохранён в ERP: ' + payload.name + ' (SKU: ' + payload.sku + ')');
            modalForm.reset();
            closeModal();
          });
        }

        // MP Settings modal logic
        const mpBackdrop = document.getElementById('mpModalBackdrop');
        const mpDialog = document.getElementById('mpModal');
        const mpClose = document.getElementById('mpCloseBtn');
        const mpCancel = document.getElementById('mpCancelBtn');
        const wbCancel = document.getElementById('wbCancelBtn');
        const ymCancel = document.getElementById('ymCancelBtn');
        const tabButtons = document.querySelectorAll('[role="tab"]');
        const tabPanels = document.querySelectorAll('[role="tabpanel"]');

        function setMpOpen(isOpen) {
          const backdropEl = document.getElementById('mpModalBackdrop');
          const dialogEl = document.getElementById('mpModal');
          if (!backdropEl || !dialogEl) return;
          if (isOpen) {
            dialogEl.removeAttribute('inert');
            backdropEl.classList.remove('hidden');
            dialogEl.classList.remove('hidden');
            backdropEl.style.pointerEvents = 'auto';
            backdropEl.style.display = 'flex';
            dialogEl.style.display = '';
            dialogEl.style.pointerEvents = 'auto';
            document.body.style.overflow = 'hidden';
            // Focus management
            dialogEl.focus();
            const first = dialogEl.querySelector('input, button, textarea, [tabindex]:not([tabindex="-1"])');
            if (first) first.focus();
          } else {
            // Blur any active control in the dialog first
            const active = document.activeElement;
            if (active && dialogEl.contains(active) && active instanceof HTMLElement) { active.blur(); }
            dialogEl.setAttribute('inert', '');
            dialogEl.classList.add('hidden');
            backdropEl.classList.add('hidden');
            backdropEl.style.pointerEvents = 'none';
            backdropEl.style.display = 'none';
            dialogEl.style.display = 'none';
            dialogEl.style.pointerEvents = 'none';
            document.body.style.overflow = '';
            if (mpSettingsButton) mpSettingsButton.focus();
          }
        }

        function openMpModal() { setMpOpen(true); }
        function closeMpModal() { setMpOpen(false); }
        
        function openMpModalForMarketplace(marketplace) {
          setMpOpen(true);
          // Переключаем на нужную вкладку
          setTimeout(() => {
            let tabId = '';
            switch(marketplace) {
              case 'ozon':
                tabId = 'tab-ozon';
                break;
              case 'wildberries':
              case 'wb':
                tabId = 'tab-wb';
                break;
              case 'yandexmarket':
              case 'ym':
              case 'yandex':
                tabId = 'tab-ym';
                break;
            }
            if (tabId) {
              const tab = document.getElementById(tabId);
              if (tab) {
                tab.click();
                console.log('Opened modal for marketplace:', marketplace, 'switched to tab:', tabId);
              } else {
                console.warn('Tab not found:', tabId, 'for marketplace:', marketplace);
              }
            } else {
              console.warn('Unknown marketplace:', marketplace);
            }
          }, 50);
        }
        // Expose fallback closer globally for inline handlers
        window.__closeMp = closeMpModal;
        window.openMpModalForMarketplace = openMpModalForMarketplace;
        function activateTab(tabId) {
          tabButtons.forEach(btn => {
            const selected = btn.id === tabId;
            btn.setAttribute('aria-selected', String(selected));
            btn.tabIndex = selected ? 0 : -1;
          });
          tabPanels.forEach(panel => {
            const active = panel.getAttribute('aria-labelledby') === tabId;
            panel.classList.toggle('active', active);
            panel.hidden = !active;
          });
        }

        if (mpSettingsButton) mpSettingsButton.addEventListener('click', openMpModal);
        if (mpClose) mpClose.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); closeMpModal(); });
        if (mpCancel) mpCancel.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); closeMpModal(); });
        if (wbCancel) wbCancel.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); closeMpModal(); });
        if (ymCancel) ymCancel.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); closeMpModal(); });
        // Also bind any .modal-close inside marketplace modal
        if (mpDialog) {
          const mpCloseBtns = mpDialog.querySelectorAll('.modal-close');
          mpCloseBtns.forEach(function (btn) {
            btn.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); closeMpModal(); });
          });
        }
        if (mpBackdrop) {
          mpBackdrop.addEventListener('click', function (e) { if (e.target === mpBackdrop) closeMpModal(); });
        }
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            if (mpBackdrop && !mpBackdrop.classList.contains('hidden')) closeMpModal();
            else if (addCategoryModalBackdrop && !addCategoryModalBackdrop.classList.contains('hidden')) closeCategoryModal();
          }
        });
        // Extra safety: delegate close on cross buttons
        document.addEventListener('click', function (e) {
          let t = e.target;
          if (!(t instanceof Element)) return;
          // If text node or child inside, climb up to element
          if (t.nodeType !== 1 && t.parentElement) t = t.parentElement;
          if (t.id === 'mpCloseBtn' || t.closest('#mpCloseBtn') || (t.closest('#mpModal') && t.classList.contains('modal-close')) || (t.closest('#mpModal') && t.getAttribute('data-action') === 'close-mp')) {
            e.preventDefault();
            closeMpModal();
          }
          if (t.id === 'modalCloseBtn' || t.closest('#modalCloseBtn') || (t.closest('#productModal') && t.classList.contains('modal-close'))) {
            e.preventDefault();
            closeModal();
          }
        });
        const tabArray = Array.from(tabButtons);
        tabArray.forEach((btn, index) => {
          btn.addEventListener('click', function () { activateTab(btn.id); });
          btn.addEventListener('keydown', function (e) {
            const lastIdx = tabArray.length - 1;
            let nextIndex = index;
            if (e.key === 'ArrowRight') nextIndex = index === lastIdx ? 0 : index + 1;
            else if (e.key === 'ArrowLeft') nextIndex = index === 0 ? lastIdx : index - 1;
            else if (e.key === 'Home') nextIndex = 0;
            else if (e.key === 'End') nextIndex = lastIdx;
            else if (e.key === 'Enter' || e.key === ' ') { activateTab(btn.id); return; }
            else return;
            e.preventDefault();
            const next = tabArray[nextIndex];
            if (next) next.focus();
          });
        });

        // Storage helpers
        const storageKeys = {
          ozon: 'mp:ozon',
          wb: 'mp:wildberries',
          ym: 'mp:yandex'
        };
        function saveConfig(key, obj) { localStorage.setItem(key, JSON.stringify(obj)); }
        function loadConfig(key) {
          try { const raw = localStorage.getItem(key); return raw ? JSON.parse(raw) : {}; } catch { return {}; }
        }
        
        // Categories storage functions
        function saveCategories(categories) { localStorage.setItem('categories', JSON.stringify(categories)); }
        function loadCategories() {
          try { const raw = localStorage.getItem('categories'); return raw ? JSON.parse(raw) : []; } catch { return []; }
        }
        function addCategory(newCategory) {
          const categories = loadCategories();
          categories.push(newCategory);
          saveCategories(categories);
          return categories;
        }
        
        function deleteCategory(categoryId) {
          const categories = loadCategories();
          
          // Приводим ID к числу для корректного сравнения
          const numericId = parseInt(categoryId, 10);
          
          console.log('Deleting category:', categoryId, 'as numeric:', numericId);
          console.log('Categories before deletion:', categories.length);
          
          // Удаляем саму категорию и все её подкатегории
          const updatedCategories = categories.filter(cat => {
            // Удаляем категорию с указанным ID
            if (cat.id === numericId) {
              console.log('Found category to delete:', cat.name, 'ID:', cat.id);
              return false;
            }
            
            // Удаляем все подкатегории этой категории
            if (cat.parentId === numericId) {
              console.log('Found subcategory to delete:', cat.name, 'Parent ID:', cat.parentId);
              return false;
            }
            
            return true;
          });
          
          console.log('Categories after deletion:', updatedCategories.length);
          
          saveCategories(updatedCategories);
          return updatedCategories;
        }

        // Bind forms
        function bindForm(formId, key, requiredFields, testBtnId, tester) {
          const form = document.getElementById(formId);
          const testBtn = document.getElementById(testBtnId);
          if (!form) return;

          // Fill from storage
          const existing = loadConfig(key);
          Array.from(form.elements).forEach(el => {
            if (el && 'name' in el && existing[el.name] != null) { el.value = existing[el.name]; }
          });

          form.addEventListener('submit', function (e) {
            e.preventDefault();
            const data = Object.fromEntries(new FormData(form));
            const errors = [];
            requiredFields.forEach(f => { if (!String(data[f] || '').trim()) errors.push('Заполните поле: ' + f); });
            const errBox = form.querySelector('.error');
            if (errBox) errBox.textContent = errors[0] || '';
            if (errors.length) return;
            saveConfig(key, data);
            alert('Настройки сохранены');
          });

          if (testBtn) {
            testBtn.addEventListener('click', async function () {
              const data = Object.fromEntries(new FormData(form));
              const missing = requiredFields.filter(f => !String(data[f] || '').trim());
              if (missing.length) { alert('Заполните обязательные поля: ' + missing.join(', ')); return; }
              testBtn.disabled = true; const prevText = testBtn.textContent; testBtn.textContent = 'Проверка...';
              try {
                if (typeof tester === 'function') {
                  const result = await tester(data);
                  alert(result.ok ? 'Подключение успешно' : ('Ошибка: ' + (result.message || 'Неизвестная ошибка')));
                } else {
                  alert('Тестер не настроен');
                }
              } catch (e) {
                const msg = (e && e.message) ? e.message : String(e);
                alert('Ошибка при проверке: ' + msg);
              } finally {
                testBtn.disabled = false; testBtn.textContent = prevText || 'Проверить подключение';
              }
            });
          }
        }

        // Testers with graceful CORS/timeout handling
        function withTimeout(promise, ms) {
          const ctrl = new AbortController();
          const t = setTimeout(() => ctrl.abort(), ms);
          return { run: (exec) => exec(ctrl, t), signal: ctrl.signal };
        }

        async function testOzon(data) {
          const url = 'http://localhost:3001/test/ozon';
          try {
            const r = await fetch(url, { 
              method: 'POST', 
              headers: { 'Content-Type': 'application/json' }, 
              body: JSON.stringify({ client_id: data.client_id, api_key: data.api_key }),
              signal: AbortSignal.timeout(15000) // 15 second timeout
            });
            
            if (!r.ok) {
              const errorText = await r.text().catch(() => 'Неизвестная ошибка');
              return { ok: false, message: `HTTP ${r.status}: ${errorText.slice(0, 200)}` };
            }
            
            const json = await r.json().catch(() => ({}));
            return { ok: json.ok === true, message: json.message || 'Подключение к Ozon успешно' };
          } catch (e) {
            if (e.name === 'AbortError') {
              return { ok: false, message: 'Таймаут подключения (15 сек)' };
            }
            if (e.name === 'TypeError' && e.message.includes('fetch')) {
              return { ok: false, message: 'Сервер недоступен. Убедитесь, что сервер запущен на порту 3001.' };
            }
            return { ok: false, message: `Ошибка подключения: ${e.message}` };
          }
        }

        async function testWB(data) {
          const url = 'http://localhost:3001/test/wb';
          try {
            const r = await fetch(url, { 
              method: 'POST', 
              headers: { 'Content-Type': 'application/json' }, 
